      "bestFor": ["human aesthetic score distribution", "composition", "photo quality"],
      "risks": ["photography bias"],
      "modalities": ["visual", "composition", "aesthetic_score", "emotion_tags"],
      "priority": 1
    },
    {
      "id": "polyvore",
      "name": "Polyvore Outfits Dataset",
      "status": "recommended_for_compatibility_model",
      "assetPolicy": "check_original_dataset_terms",
      "bestFor": ["aesthetic compatibility", "color harmony", "style co-presence"],
      "risks": ["fashion-specific domain"],
      "modalities": ["objects", "colors", "style_tags", "relations"],
      "priority": 3
    },
    {
      "id": "danbooru",
      "name": "Danbooru",
      "status": "safe_subset_only",
      "assetPolicy": "metadata_first_safe_rating_filter_required",
      "bestFor": ["granular tags", "symbols", "objects", "style taxonomy"],
      "risks": ["NSFW filtering required", "anime and fan-art bias", "IP sensitivity"],
      "modalities": ["objects", "symbols", "style_tags", "composition"],
      "priority": 3
    }
  ],
  "trainingRoadmap": [
    {
      "stage": "MVP",
      "action": "Build local multimodal observations from SigLIP2 + Florence-2 + palette analysis, then store records in the common schema."
    },
    {
      "stage": "Data factory",
      "action": "Create adapters per dataset, normalize metadata into commonSampleSchema, and keep assets metadata-only until each license path is validated."
    },
    {
      "stage": "Specialist heads",
      "action": "Train or fine-tune modality-specific heads for objects, symbols, textures, style, composition, affect and aesthetic score."
    },
    {
      "stage": "Fusion encoder",
      "action": "Train unified_aesthetic embeddings with contrastive image-text loss, graph-neighborhood positives, compatibility pairs and outlier negatives."
    },
    {
      "stage": "World model",
      "action": "Persist embeddings and graph relations in a vector database plus graph store, then learn trend, mutation and cluster-evolution dynamics."
    }
  ]
}
